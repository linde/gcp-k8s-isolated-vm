apiVersion: v1
kind: Service
metadata:
  name: proxied-svc
spec:
  type: LoadBalancer
  ports:
  - name: inbound
    port: 80
    targetPort: 80

---
apiVersion: v1
kind: Endpoints
metadata:
  name: proxied-svc
subsets:
  - addresses:
      - ip: ${proxied_vm_ip}
    ports:
      - name: inbound
        port: 80
