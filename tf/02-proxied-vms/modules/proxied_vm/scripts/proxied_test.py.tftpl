import http.server
import socketserver
import urllib.request
import json
import threading
import time
import os

class ProxiedHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        try:
            req = urllib.request.Request("http://httpbin.org/ip")
            with urllib.request.urlopen(req) as response:
                status = response.getcode()
                body = response.read().decode('utf-8')
                origin_ip = json.loads(body).get("origin", "unknown")
            
            self.send_response(200)
            self.send_header("Content-type", "application/json")
            self.end_headers()
            self.wfile.write(f'{{"message": "Successfully proxied ingress and egress over Geneve tunnel", "origin_ip": "{origin_ip}", "httpbin_status": {status}}}\n'.encode('utf-8'))
            print("Successfully handled GET request and IPsec proxy hit.", flush=True)
        except Exception as e:
            self.send_response(500)
            self.send_header("Content-type", "application/json")
            self.end_headers()
            self.wfile.write(f'{{"error": "Proxy request failed", "details": "{str(e)}" }}\n'.encode('utf-8'))



def run_server(port):
    host_ip = "192.168.${tunnel_id}.2"
    with socketserver.TCPServer((host_ip, port), ProxiedHandler) as httpd:
        print(f"Serving internal payload traffic directly on overlay port {port}", flush=True)
        httpd.serve_forever()

ports = [${join(", ", proxied_ports)}]
for p in ports:
    threading.Thread(target=run_server, args=(p,), daemon=True).start()

while True:
    time.sleep(3600)
