import http.server
import socketserver
import urllib.request
import urllib.parse
import json
import threading
import time
import os

class ProxiedHandler(http.server.BaseHTTPRequestHandler):
    def send_resp(self, status, data, content_type="application/json"):
        self.send_response(status)
        self.send_header("Content-type", content_type)
        self.end_headers()
        if isinstance(data, str):
            self.wfile.write(data.encode('utf-8'))
        else:
            self.wfile.write((json.dumps(data) + "\n").encode('utf-8'))

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        
        if parsed.path in ('', '/'):
            self.send_resp(200, "OK", "text/plain")
            return
            
        if parsed.path == '/proxy':
            url = urllib.parse.parse_qs(parsed.query).get('url', ['http://httpbin.org/ip'])[0]
            try:
                with urllib.request.urlopen(url) as r:
                    self.send_resp(200, {
                        "message": "Success",
                        "target_url": url,
                        "body": r.read().decode('utf-8'),
                        "status": r.getcode()
                    })
            except Exception as e:
                try:
                    self.send_resp(500, {"error": "Proxy request failed", "details": str(e)})
                except BrokenPipeError:
                    print("Broken pipe: Client disconnected", flush=True)
            return
            
        self.send_resp(404, {"error": "Not Found"})



def run_server(port):
    host_ip = "${bind_address}"
    with socketserver.TCPServer((host_ip, port), ProxiedHandler) as httpd:
        print(f"Serving internal payload traffic directly on overlay port {port}", flush=True)
        httpd.serve_forever()

ports = json.loads("${proxied_ports}")  # this is going via json so we dont have a IDE parse error
for p in ports:
    threading.Thread(target=run_server, args=(p,), daemon=True).start()

while True:
    time.sleep(3600)
